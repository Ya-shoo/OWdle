{
  "name": "owdle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,votes,feedback,trims -c cyan,yellow,blue,magenta --kill-others-on-fail \"next dev\" \"node scripts/votes-admin-server.mjs\" \"node scripts/feedback-admin-server.mjs\" \"node scripts/sound-trims-server.mjs\"",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:deploy": "node scripts/build-for-deploy.mjs",
    "deploy:live": "npm run sync-to-r2 && npm run build:deploy && wrangler pages deploy --branch=main && git push",
    "deploy:verifier": "wrangler deploy --config workers/replay-verifier/wrangler.jsonc",
    "votes:admin": "node scripts/votes-admin-server.mjs",
    "feedback:admin": "node scripts/feedback-admin-server.mjs",
    "sound:trims": "node scripts/sound-trims-server.mjs",
    "sync-clips": "bash -c 'for f in ~/Downloads/owdle-clips*.zip; do unzip -o \"$f\" -d public/; done' && node scripts/build-sound-clips.mjs",
    "sync-to-r2": "node scripts/sync-to-r2.mjs"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "modern-screenshot": "^4.7.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "posthog-js": "^1.374.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tesseract.js": "^7.0.0",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "ffmpeg-static": "^5.3.0",
    "mime": "^4.1.0",
    "sharp": "^0.32.6",
    "smartcrop-sharp": "^2.0.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  }
}
