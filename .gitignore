# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# wrangler local secrets (Discord bot token etc. for `wrangler pages dev`)
.dev.vars
.dev.vars.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code / wrangler local state
/.claude/
/.wrangler/

# media — hosted in Cloudflare R2 via lib/media.ts + NEXT_PUBLIC_MEDIA_BASE.
# Local files in these directories are working state for capture /
# labeling; canonical store is the R2 bucket synced via `npm run sync-to-r2`.
/public/sounds/
/public/melee/
/public/maps/
/public/skins/
/public/voicelines/
/public/banners/
# staging dir used by scripts/build-for-deploy.mjs to keep media out of out/
/.staged-media/

# scripts/sync-to-r2.mjs cache of confirmed-present keys; lets repeated
# deploys skip the HEAD check on already-uploaded files (R2 rate-limits
# the HEAD-via-GET endpoint after ~1500 requests).
/.r2-sync-cache.json
